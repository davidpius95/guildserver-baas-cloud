{
  "name": "guildserver-baas-cloud",
  "version": "1.0.0",
  "description": "Self-hosted Supabase Cloud platform — multi-tenant BaaS on your own infrastructure",
  "private": true,
  "workspaces": ["apps/*", "packages/*"],
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "start": "turbo run start",
    "typecheck": "turbo run typecheck",
