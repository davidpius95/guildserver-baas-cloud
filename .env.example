# ── Platform Database ─────────────────────────────────────────────────────────
# Dedicated BaaS platform Postgres (docker-compose exposes it on host port 5434)
DATABASE_URL=postgres://postgres:strong-admin-password@localhost:5434/postgres
BAAS_PG_ADMIN_PASSWORD=strong-admin-password

# ── Secrets encryption ────────────────────────────────────────────────────────
# 32-byte key, base64-encoded. Generate with: openssl rand -base64 32
# The API refuses to start if this is missing or not 32 bytes when decoded.
BAAS_ENCRYPTION_KEY=

# ── Auth ──────────────────────────────────────────────────────────────────────
JWT_SECRET=change-me-min-32-chars
JWT_EXPIRES_IN=7d

# ── API ───────────────────────────────────────────────────────────────────────
BAAS_API_PORT=4001
BAAS_WEB_URL=http://localhost:3001
BAAS_BASE_DOMAIN=baas.localhost
BAAS_FALLBACK_DOMAIN=baas.guildserver.com
BAAS_TLS=false                       # true in production
BAAS_CERT_RESOLVER=letsencrypt       # Traefik cert resolver name

# ── Tenant data & ports ───────────────────────────────────────────────────────
TENANT_DATA_DIR=/opt/baas-tenants    # Per-tenant compose files + volumes
BAAS_BACKUP_DIR=/opt/baas-backups    # Backup storage directory
BAAS_TENANT_PORT_RANGE_START=9000    # First host port a tenant window may use
BAAS_TENANT_PORT_RANGE_END=65000     # Last host port a tenant window may use

# ── Redis (BullMQ job queues) ─────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379

# ── Cloudflare (custom domains — leave blank to skip domain features) ─────────
CF_ZONE_ID=
CF_API_TOKEN=

# ── SMTP (forwarded to GoTrue inside each tenant) ─────────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# ── Docker ────────────────────────────────────────────────────────────────────
BAAS_DOCKER_NETWORK=guildserver      # Docker network all tenant stacks join

# ── Frontend ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_BAAS_API_URL=http://localhost:4001
NEXT_PUBLIC_PAAS_WEB_URL=http://localhost:3000
